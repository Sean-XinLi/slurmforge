from __future__ import annotations

import argparse
import json
import os
from pathlib import Path


# ─────────────────────────────────────────────────────────────────────────────
# UTILITIES  ·  slurmforge internal helpers  [keep as-is]
# ─────────────────────────────────────────────────────────────────────────────

def _runtime_dir(env_name: str, fallback: str) -> Path:
    return Path(os.environ.get(env_name, fallback)).resolve()


def _write_json(path: Path, payload: dict) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(payload, indent=2, sort_keys=True), encoding="utf-8")


# ─────────────────────────────────────────────────────────────────────────────
# SECTION A  ·  SLURMFORGE ARG CONTRACT  [keep as-is]
# ─────────────────────────────────────────────────────────────────────────────
# slurmforge injects the last two args below at job submission time:
#   --resume_from_checkpoint  ← set automatically when a job is resumed
#   --model_overrides_json    ← populated during hyperparameter sweeps
#
#   ✔  ADD your own hyperparameters below (--epochs, --hidden_dim, etc.).
#   ✘  Do NOT remove or rename --resume_from_checkpoint / --model_overrides_json.
# ─────────────────────────────────────────────────────────────────────────────

def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser()
    # TODO: Replace the demo args below with your own training hyperparameters.
    parser.add_argument("--max_length", type=int, required=True)
    parser.add_argument("--epochsize", type=int, required=True)
    parser.add_argument("--lr", type=float, required=True)
    parser.add_argument("--batch_size", type=int, default=32)
    parser.add_argument("--use_amp", action="store_true")
    # ↓ slurmforge contract — keep these two args
    parser.add_argument("--resume_from_checkpoint", default="")
    parser.add_argument("--model_overrides_json", default="")
    return parser.parse_args()


def main() -> None:
    args = parse_args()

    # slurmforge sets these env vars at runtime; fallbacks are for local runs.
    result_dir     = _runtime_dir("AI_INFRA_RESULT_DIR",     "./local_results")
    checkpoint_dir = _runtime_dir("AI_INFRA_CHECKPOINT_DIR", "./local_results/checkpoints")
    meta_dir       = _runtime_dir("AI_INFRA_META_DIR",       "./local_results/meta")

    # slurmforge populates these from experiment.yaml at submission time.
    model_overrides = json.loads(args.model_overrides_json) if args.model_overrides_json else {}
    resume_from     = args.resume_from_checkpoint or os.environ.get("AI_INFRA_RESUME_FROM_CHECKPOINT", "")

    # ─────────────────────────────────────────────────────────────────────────
    # SECTION B  ·  YOUR TRAINING CODE  [replace this block]
    # ─────────────────────────────────────────────────────────────────────────
    # Inputs ready to use:
    #   args            — your parsed hyperparameters
    #   resume_from     — checkpoint path to resume from (empty = fresh run)
    #   model_overrides — dict of sweep overrides injected by slurmforge (empty = no sweep)
    #   result_dir      — write output artefacts here
    #   checkpoint_dir  — write checkpoints here
    #
    # Required by slurmforge after training completes:
    #   checkpoint_dir / "last.ckpt"         ← must exist (used for resume & run lineage)
    #   result_dir / "train_summary.json"    ← recommended (shown in sforge status)
    #
    # TODO: Delete the demo block below and insert your real training loop.
    # ─────────────────────────────────────────────────────────────────────────

    # ↓↓↓ DEMO PLACEHOLDER — delete everything between these markers ↓↓↓
    payload = {
        "max_length": args.max_length,
        "epochsize": args.epochsize,
        "lr": args.lr,
        "batch_size": args.batch_size,
        "use_amp": args.use_amp,
    }
    _write_json(result_dir / "train_summary.json", payload)
    checkpoint_dir.mkdir(parents=True, exist_ok=True)
    (checkpoint_dir / "last.ckpt").write_text("replace with real checkpoint save\n", encoding="utf-8")
    print("[demo] training finished — replace this with your real training loop")
    # ↑↑↑ DEMO PLACEHOLDER — delete everything between these markers ↑↑↑

    # ─────────────────────────────────────────────────────────────────────────
    # SECTION C  ·  SLURMFORGE OUTPUT CONTRACT  [keep as-is]
    # ─────────────────────────────────────────────────────────────────────────
    # slurmforge reads meta_dir after every run for bookkeeping.
    # ─────────────────────────────────────────────────────────────────────────
    _write_json(meta_dir / "train_metadata.json", {
        "resume_from": resume_from,
        "model_overrides": model_overrides,
    })


if __name__ == "__main__":
    main()
