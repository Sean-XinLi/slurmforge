from __future__ import annotations

import os
from pathlib import Path


# ─────────────────────────────────────────────────────────────────────────────
# SLURMFORGE ENV VAR CONTRACT  ·  available inside run.command at runtime
# ─────────────────────────────────────────────────────────────────────────────
# Read these environment variables inside your own training script to integrate
# with the slurmforge output and checkpoint pipeline.
#
# Required outputs that slurmforge reads after your command exits:
#   checkpoint_dir / "last.ckpt"         ← must exist (used for resume & run lineage)
#   result_dir / "train_summary.json"    ← recommended (shown in sforge status)
#   meta_dir / "train_metadata.json"     ← slurmforge bookkeeping
# ─────────────────────────────────────────────────────────────────────────────

def show_injected_env() -> None:
    result_dir     = Path(os.environ.get("AI_INFRA_RESULT_DIR",     "./local_results"))
    checkpoint_dir = Path(os.environ.get("AI_INFRA_CHECKPOINT_DIR", "./local_results/checkpoints"))
    meta_dir       = Path(os.environ.get("AI_INFRA_META_DIR",       "./local_results/meta"))
    resume_from    = os.environ.get("AI_INFRA_RESUME_FROM_CHECKPOINT", "")

    print(f"result_dir:     {result_dir}")
    print(f"checkpoint_dir: {checkpoint_dir}")
    print(f"meta_dir:       {meta_dir}")
    print(f"resume_from:    {resume_from or '(fresh run)'}")


if __name__ == "__main__":
    show_injected_env()
