from __future__ import annotations

import argparse
import csv
import json
import os
from pathlib import Path


def _runtime_dir(env_name: str, fallback: str) -> Path:
    return Path(os.environ.get(env_name, fallback)).resolve()


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser()
    parser.add_argument("--test_size", type=float, required=True)
    parser.add_argument("--run_args_json", default="{}")
    return parser.parse_args()


def main() -> None:
    args = parse_args()

    eval_csv_dir = _runtime_dir("AI_INFRA_EVAL_CSV_DIR", "./local_results/eval_csv")
    eval_image_dir = _runtime_dir("AI_INFRA_EVAL_IMAGE_DIR", "./local_results/eval_images")
    run_args = json.loads(args.run_args_json or "{}")

    eval_csv_dir.mkdir(parents=True, exist_ok=True)
    eval_image_dir.mkdir(parents=True, exist_ok=True)

    with (eval_csv_dir / "metrics.csv").open("w", encoding="utf-8", newline="") as fp:
        writer = csv.writer(fp)
        writer.writerow(["metric", "value"])
        writer.writerow(["test_size", args.test_size])
        writer.writerow(["run_arg_count", len(run_args)])

    (eval_image_dir / "summary.txt").write_text(
        f"test_size={args.test_size} run_arg_count={len(run_args)}\n",
        encoding="utf-8",
    )
    print(f"eval finished: test_size={args.test_size}")


if __name__ == "__main__":
    main()
