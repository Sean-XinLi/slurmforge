[importlinter]
root_packages =
    slurmforge

# ----------------------------------------------------------------------------
# Contract 1: schema/ is the leaf kernel.
# Pure dataclasses + io primitives only; importing any other internal package
# is a structural regression. Add allowed deps here only if absolutely
# necessary.
# ----------------------------------------------------------------------------
[importlinter:contract:1]
name = schema kernel is leaf
type = forbidden
source_modules =
    slurmforge.schema
forbidden_modules =
    slurmforge.cli
    slurmforge.controller
    slurmforge.emit
    slurmforge.executor
    slurmforge.inputs
    slurmforge.lineage
    slurmforge.notifications
    slurmforge.orchestration
    slurmforge.outputs
    slurmforge.plans
    slurmforge.planner
    slurmforge.read_models
    slurmforge.resolver
    slurmforge.runtime
    slurmforge.sizing
    slurmforge.slurm
    slurmforge.spec
    slurmforge.status
    slurmforge.storage
    slurmforge.submission

# ----------------------------------------------------------------------------
# Contract 2: io/ is the canonical home for serialization primitives.
# Other modules must `from slurmforge.io import …`, never re-implement
# to_jsonable / stable_json / require_schema / SchemaVersion.
# ----------------------------------------------------------------------------
[importlinter:contract:2]
name = io is a leaf
type = forbidden
source_modules =
    slurmforge.io
forbidden_modules =
    slurmforge.cli
    slurmforge.controller
    slurmforge.emit
    slurmforge.executor
    slurmforge.inputs
    slurmforge.lineage
    slurmforge.notifications
    slurmforge.orchestration
    slurmforge.outputs
    slurmforge.plans
    slurmforge.planner
    slurmforge.read_models
    slurmforge.resolver
    slurmforge.runtime
    slurmforge.schema
    slurmforge.sizing
    slurmforge.slurm
    slurmforge.spec
    slurmforge.status
    slurmforge.storage
    slurmforge.submission

# ----------------------------------------------------------------------------
# Contract 3: emit/sbatch helpers are intra-package only.
# emit.sbatch_helpers holds shell-quoting / job-name helpers used by emit.controller
# and emit.stage. External packages must consume the public renderers
# (write_stage_submit_files, write_controller_submit_file, ...) only.
# ----------------------------------------------------------------------------
[importlinter:contract:3]
name = emit sbatch helpers are package-private
type = forbidden
source_modules =
    slurmforge.cli
    slurmforge.controller
    slurmforge.executor
    slurmforge.inputs
    slurmforge.lineage
    slurmforge.notifications
    slurmforge.orchestration
    slurmforge.outputs
    slurmforge.planner
    slurmforge.read_models
    slurmforge.resolver
    slurmforge.runtime
    slurmforge.sizing
    slurmforge.spec
    slurmforge.status
    slurmforge.storage
    slurmforge.submission
forbidden_modules =
    slurmforge.emit.sbatch_helpers
ignore_imports =
    slurmforge.emit.controller -> slurmforge.emit.sbatch_helpers
    slurmforge.emit.stage -> slurmforge.emit.sbatch_helpers
    slurmforge.emit.stage_render -> slurmforge.emit.sbatch_helpers

# ----------------------------------------------------------------------------
# Contract 4: status internals are package-private.
# All stage status writes must enter through ``slurmforge.status`` (the
# package's public API in __init__.py). status.machine is the sole writer
# of status.json / attempt.json; reader/query/serde/root_ref are internal
# helpers behind that facade.
# ignore_imports whitelists the legitimate intra-package re-export chain.
# ----------------------------------------------------------------------------
[importlinter:contract:4]
name = status internals go through package facade
type = forbidden
source_modules =
    slurmforge.cli
    slurmforge.controller
    slurmforge.emit
    slurmforge.executor
    slurmforge.inputs
    slurmforge.lineage
    slurmforge.notifications
    slurmforge.orchestration
    slurmforge.outputs
    slurmforge.planner
    slurmforge.read_models
    slurmforge.resolver
    slurmforge.runtime
    slurmforge.sizing
    slurmforge.spec
    slurmforge.storage
    slurmforge.submission
forbidden_modules =
    slurmforge.status.machine
    slurmforge.status.query
    slurmforge.status.reader
    slurmforge.status.root_ref
    slurmforge.status.serde
ignore_imports =
    slurmforge.status -> slurmforge.status.machine
    slurmforge.status -> slurmforge.status.query
    slurmforge.status -> slurmforge.status.reader
    slurmforge.status -> slurmforge.status.root_ref
    slurmforge.status -> slurmforge.status.serde
    slurmforge.status.reconcile -> slurmforge.status.machine
    slurmforge.status.reconcile -> slurmforge.status.reader
    slurmforge.status.reconcile_state -> slurmforge.status.machine
    slurmforge.status.reconcile_state -> slurmforge.status.reader

# ----------------------------------------------------------------------------
# Contract 5: storage.paths is storage-internal.
# External packages may import explicit storage role modules
# (layout, loader, controller, materialization), but must not bind directly to
# raw path helpers.
# ----------------------------------------------------------------------------
[importlinter:contract:5]
name = storage paths are package-private
type = forbidden
allow_indirect_imports = True
source_modules =
    slurmforge.cli
    slurmforge.controller
    slurmforge.emit
    slurmforge.executor
    slurmforge.inputs
    slurmforge.lineage
    slurmforge.notifications
    slurmforge.orchestration
    slurmforge.outputs
    slurmforge.plans
    slurmforge.planner
    slurmforge.read_models
    slurmforge.resolver
    slurmforge.runtime
    slurmforge.schema
    slurmforge.sizing
    slurmforge.slurm
    slurmforge.spec
    slurmforge.status
    slurmforge.submission
forbidden_modules =
    slurmforge.storage.paths

# ----------------------------------------------------------------------------
# Contract 6: submission internals are accessed through the package facade.
# External packages use ``slurmforge.submission``; only the submission package
# itself may reach generation/submitter/ledger/reconcile/state helpers directly.
# ----------------------------------------------------------------------------
[importlinter:contract:6]
name = submission internals go through package facade
type = forbidden
source_modules =
    slurmforge.cli
    slurmforge.controller
    slurmforge.emit
    slurmforge.executor
    slurmforge.inputs
    slurmforge.lineage
    slurmforge.notifications
    slurmforge.orchestration
    slurmforge.outputs
    slurmforge.plans
    slurmforge.planner
    slurmforge.read_models
    slurmforge.resolver
    slurmforge.runtime
    slurmforge.schema
    slurmforge.sizing
    slurmforge.slurm
    slurmforge.spec
    slurmforge.status
    slurmforge.storage
forbidden_modules =
    slurmforge.submission.dependencies
    slurmforge.submission.finalizer
    slurmforge.submission.generation
    slurmforge.submission.ledger
    slurmforge.submission.models
    slurmforge.submission.queueing
    slurmforge.submission.ready
    slurmforge.submission.reconcile
    slurmforge.submission.state
    slurmforge.submission.submitter
ignore_imports =
    slurmforge.submission -> slurmforge.submission.finalizer
    slurmforge.submission -> slurmforge.submission.generation
    slurmforge.submission -> slurmforge.submission.models
    slurmforge.submission -> slurmforge.submission.reconcile
    slurmforge.submission -> slurmforge.submission.state
    slurmforge.submission -> slurmforge.submission.submitter
    slurmforge.submission.generation -> slurmforge.submission.ledger
    slurmforge.submission.ready -> slurmforge.submission.ledger
    slurmforge.submission.reconcile -> slurmforge.submission.ledger
    slurmforge.submission.state -> slurmforge.submission.ledger
    slurmforge.submission.submitter -> slurmforge.submission.dependencies
    slurmforge.submission.submitter -> slurmforge.submission.ledger
    slurmforge.submission.submitter -> slurmforge.submission.queueing
    slurmforge.submission.submitter -> slurmforge.submission.ready

# ----------------------------------------------------------------------------
# Contract 7: runtime/ is a leaf runtime-probe package.
# It can depend on errors/io only; it must not know about spec/plans/status,
# controller, executor, storage, or submission.
# ----------------------------------------------------------------------------
[importlinter:contract:7]
name = runtime is a leaf
type = forbidden
source_modules =
    slurmforge.runtime
forbidden_modules =
    slurmforge.cli
    slurmforge.controller
    slurmforge.emit
    slurmforge.executor
    slurmforge.inputs
    slurmforge.lineage
    slurmforge.notifications
    slurmforge.orchestration
    slurmforge.outputs
    slurmforge.plans
    slurmforge.planner
    slurmforge.read_models
    slurmforge.resolver
    slurmforge.schema
    slurmforge.sizing
    slurmforge.slurm
    slurmforge.spec
    slurmforge.status
    slurmforge.storage
    slurmforge.submission

# ----------------------------------------------------------------------------
# Contract 8: sizing/ is a leaf resource-estimation package.
# It owns pure sizing models and calculations. It may depend on errors/io only;
# it must not know about specs, plans, orchestration, storage, submission, or
# notification delivery.
# ----------------------------------------------------------------------------
[importlinter:contract:8]
name = sizing is a leaf
type = forbidden
source_modules =
    slurmforge.sizing
forbidden_modules =
    slurmforge.cli
    slurmforge.controller
    slurmforge.emit
    slurmforge.executor
    slurmforge.inputs
    slurmforge.lineage
    slurmforge.notifications
    slurmforge.orchestration
    slurmforge.outputs
    slurmforge.plans
    slurmforge.planner
    slurmforge.read_models
    slurmforge.resolver
    slurmforge.runtime
    slurmforge.schema
    slurmforge.slurm
    slurmforge.spec
    slurmforge.status
    slurmforge.storage
    slurmforge.submission

# ----------------------------------------------------------------------------
# Contract 9: notifications/ owns summaries, records, delivery runtime, and
# finalizer runtime. Scheduler submission for batch notification finalizers
# belongs to submission/.
# ----------------------------------------------------------------------------
[importlinter:contract:9]
name = notifications do not own scheduler submission
type = forbidden
allow_indirect_imports = True
source_modules =
    slurmforge.notifications
forbidden_modules =
    slurmforge.cli
    slurmforge.controller
    slurmforge.emit
    slurmforge.executor
    slurmforge.inputs
    slurmforge.lineage
    slurmforge.orchestration
    slurmforge.planner
    slurmforge.read_models
    slurmforge.resolver
    slurmforge.runtime
    slurmforge.slurm
    slurmforge.spec
    slurmforge.storage
    slurmforge.submission.finalizer
    slurmforge.submission.dependencies
    slurmforge.submission.generation
    slurmforge.submission.ledger
    slurmforge.submission.models
    slurmforge.submission.queueing
    slurmforge.submission.ready
    slurmforge.submission.reconcile
    slurmforge.submission.state
    slurmforge.submission.submitter
ignore_imports =
    slurmforge.notifications.finalizer_runtime -> slurmforge.slurm
    slurmforge.notifications.finalizer_runtime -> slurmforge.storage.loader
    slurmforge.notifications.read_model -> slurmforge.storage.loader

# ----------------------------------------------------------------------------
# Contract 10: read_models/ projects persisted read models only.
# It may read storage.loader, status models, plans constants, and notification
# summary input models. It must not own scheduling, orchestration, execution,
# delivery runtime, or submission.
# ----------------------------------------------------------------------------
[importlinter:contract:10]
name = read models are read-side projections
type = forbidden
allow_indirect_imports = True
source_modules =
    slurmforge.read_models
forbidden_modules =
    slurmforge.cli
    slurmforge.controller
    slurmforge.emit
    slurmforge.executor
    slurmforge.inputs
    slurmforge.lineage
    slurmforge.notifications.delivery
    slurmforge.notifications.email
    slurmforge.notifications.records
    slurmforge.orchestration
    slurmforge.outputs
    slurmforge.planner
    slurmforge.resolver
    slurmforge.runtime
    slurmforge.sizing
    slurmforge.slurm
    slurmforge.spec
    slurmforge.storage.controller
    slurmforge.storage.batch_layout
    slurmforge.storage.controller_seed
    slurmforge.storage.materialization
    slurmforge.storage.paths
    slurmforge.storage.status_seed
    slurmforge.storage.train_eval_pipeline_layout
    slurmforge.submission
