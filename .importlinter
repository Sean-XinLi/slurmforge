[importlinter]
root_packages =
    slurmforge

# ----------------------------------------------------------------------------
# Contract 1: schema/ is the leaf kernel.
# Pure dataclasses + io primitives only; importing any other internal package
# is a structural regression. Add allowed deps here only if absolutely
# necessary.
# ----------------------------------------------------------------------------
[importlinter:contract:1]
name = schema kernel is leaf
type = forbidden
source_modules =
    slurmforge.schema
forbidden_modules =
    slurmforge.cli
    slurmforge.controller
    slurmforge.emit
    slurmforge.executor
    slurmforge.inputs
    slurmforge.lineage
    slurmforge.orchestration
    slurmforge.outputs
    slurmforge.plans
    slurmforge.planner
    slurmforge.resolver
    slurmforge.runtime
    slurmforge.slurm
    slurmforge.spec
    slurmforge.status
    slurmforge.storage
    slurmforge.submission

# ----------------------------------------------------------------------------
# Contract 2: io/ is the canonical home for serialization primitives.
# Other modules must `from slurmforge.io import …`, never re-implement
# to_jsonable / stable_json / require_schema / SchemaVersion.
# ----------------------------------------------------------------------------
[importlinter:contract:2]
name = io is a leaf
type = forbidden
source_modules =
    slurmforge.io
forbidden_modules =
    slurmforge.cli
    slurmforge.controller
    slurmforge.emit
    slurmforge.executor
    slurmforge.inputs
    slurmforge.lineage
    slurmforge.orchestration
    slurmforge.outputs
    slurmforge.plans
    slurmforge.planner
    slurmforge.resolver
    slurmforge.runtime
    slurmforge.schema
    slurmforge.slurm
    slurmforge.spec
    slurmforge.status
    slurmforge.storage
    slurmforge.submission

# ----------------------------------------------------------------------------
# Contract 3: emit/sbatch helpers are intra-package only.
# emit.sbatch holds shell-quoting / job-name helpers used by emit.controller
# and emit.stage. External packages must consume the public renderers
# (write_stage_submit_files, write_controller_submit_file, ...) only.
# ----------------------------------------------------------------------------
[importlinter:contract:3]
name = emit sbatch helpers are package-private
type = forbidden
source_modules =
    slurmforge.cli
    slurmforge.controller
    slurmforge.executor
    slurmforge.inputs
    slurmforge.lineage
    slurmforge.orchestration
    slurmforge.outputs
    slurmforge.planner
    slurmforge.resolver
    slurmforge.runtime
    slurmforge.spec
    slurmforge.status
    slurmforge.storage
    slurmforge.submission
forbidden_modules =
    slurmforge.emit.sbatch
ignore_imports =
    slurmforge.emit.controller -> slurmforge.emit.sbatch
    slurmforge.emit.stage -> slurmforge.emit.sbatch

# ----------------------------------------------------------------------------
# Contract 4: status state machine + root_ref are package-private.
# All stage status writes must enter through ``slurmforge.status`` (the
# package's public API in __init__.py). status.machine is the sole writer
# of status.json / attempt.json; root_ref is an internal helper.
# ignore_imports whitelists the legitimate intra-package re-export chain.
# ----------------------------------------------------------------------------
[importlinter:contract:4]
name = status machine is sole writer
type = forbidden
source_modules =
    slurmforge.cli
    slurmforge.controller
    slurmforge.emit
    slurmforge.executor
    slurmforge.inputs
    slurmforge.lineage
    slurmforge.orchestration
    slurmforge.outputs
    slurmforge.planner
    slurmforge.resolver
    slurmforge.runtime
    slurmforge.spec
    slurmforge.storage
    slurmforge.submission
forbidden_modules =
    slurmforge.status.machine
    slurmforge.status.root_ref
ignore_imports =
    slurmforge.status -> slurmforge.status.machine
    slurmforge.status -> slurmforge.status.root_ref
    slurmforge.status.reconcile -> slurmforge.status.machine

# ----------------------------------------------------------------------------
# Contract 5: storage/ public API is layout + loader + materialization.
# Internal modules of submission/, status/, emit/, etc. must be
# accessed through their package facades.
# ----------------------------------------------------------------------------
[importlinter:contract:5]
name = storage submodules go through package facade
type = forbidden
source_modules =
    slurmforge.cli
    slurmforge.controller
    slurmforge.executor
    slurmforge.lineage
    slurmforge.orchestration
    slurmforge.outputs
    slurmforge.planner
    slurmforge.resolver
    slurmforge.runtime
    slurmforge.spec
    slurmforge.submission
forbidden_modules =
    slurmforge.storage.aggregate
    slurmforge.storage.controller
    slurmforge.storage.layout
    slurmforge.storage.loader
    slurmforge.storage.materialization
    slurmforge.storage.paths
ignore_imports =
    slurmforge.storage -> slurmforge.storage.aggregate
    slurmforge.storage -> slurmforge.storage.controller
    slurmforge.storage -> slurmforge.storage.layout
    slurmforge.storage -> slurmforge.storage.loader
    slurmforge.storage -> slurmforge.storage.materialization
    slurmforge.storage -> slurmforge.storage.paths
    slurmforge.storage.aggregate -> slurmforge.storage.loader
    slurmforge.storage.controller -> slurmforge.storage.paths
    slurmforge.storage.layout -> slurmforge.storage.aggregate
    slurmforge.storage.layout -> slurmforge.storage.materialization
    slurmforge.storage.layout -> slurmforge.storage.paths
    slurmforge.storage.loader -> slurmforge.storage.paths
    slurmforge.storage.materialization -> slurmforge.storage.layout

# ----------------------------------------------------------------------------
# Contract 6: submission internals are accessed through the package facade.
# External packages use ``slurmforge.submission``; only the submission package
# itself may reach generation/submitter/ledger/reconcile directly.
# ----------------------------------------------------------------------------
[importlinter:contract:6]
name = submission internals go through package facade
type = forbidden
source_modules =
    slurmforge.cli
    slurmforge.controller
    slurmforge.emit
    slurmforge.executor
    slurmforge.inputs
    slurmforge.lineage
    slurmforge.orchestration
    slurmforge.outputs
    slurmforge.plans
    slurmforge.planner
    slurmforge.resolver
    slurmforge.runtime
    slurmforge.schema
    slurmforge.slurm
    slurmforge.spec
    slurmforge.status
    slurmforge.storage
forbidden_modules =
    slurmforge.submission.generation
    slurmforge.submission.ledger
    slurmforge.submission.reconcile
    slurmforge.submission.submitter
ignore_imports =
    slurmforge.submission -> slurmforge.submission.generation
    slurmforge.submission -> slurmforge.submission.ledger
    slurmforge.submission -> slurmforge.submission.reconcile
    slurmforge.submission -> slurmforge.submission.submitter
    slurmforge.submission.generation -> slurmforge.submission.ledger
    slurmforge.submission.reconcile -> slurmforge.submission.ledger
    slurmforge.submission.submitter -> slurmforge.submission.ledger

# ----------------------------------------------------------------------------
# Contract 7: runtime/ is a leaf runtime-probe package.
# It can depend on errors/io only; it must not know about spec/plans/status,
# controller, executor, storage, or submission.
# ----------------------------------------------------------------------------
[importlinter:contract:7]
name = runtime is a leaf
type = forbidden
source_modules =
    slurmforge.runtime
forbidden_modules =
    slurmforge.cli
    slurmforge.controller
    slurmforge.emit
    slurmforge.executor
    slurmforge.inputs
    slurmforge.lineage
    slurmforge.orchestration
    slurmforge.outputs
    slurmforge.plans
    slurmforge.planner
    slurmforge.resolver
    slurmforge.schema
    slurmforge.slurm
    slurmforge.spec
    slurmforge.status
    slurmforge.storage
    slurmforge.submission
